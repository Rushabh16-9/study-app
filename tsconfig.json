{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "src",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "es2020",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "target": "ES2022",
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "es2018",
      "dom"
    ],
    "paths": {
      "app-shared-services/*": [
        "app/shared/services/*"
      ],
      "app-shared-components/*": [
        "app/shared/components/*"
      ]
    },
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": false
  }
}